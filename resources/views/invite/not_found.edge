<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Invitation not found</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />
    <link rel="stylesheet" href="https://unpkg.com/primeicons@7.0.0/primeicons.css" />

    <style>
      :root {
        --p-slate-200: #e2e8f0;
        --p-slate-300: #cbd5e1;
        --p-slate-500: #64748b;
        --p-slate-900: #0f172a;
        --ink: var(--p-slate-900);
        --ink-3: var(--p-slate-500);
        --line: var(--p-slate-200);
        --bg-2: #f8fafc;
      }
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
        background: var(--bg-2);
        color: var(--ink);
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
        -webkit-font-smoothing: antialiased;
      }
      .page {
        position: relative;
        text-align: center;
        max-width: 440px;
      }
      .page::before {
        content: '';
        position: absolute;
        pointer-events: none;
        width: 560px;
        height: 560px;
        top: -260px;
        left: 50%;
        transform: translateX(-50%);
        background: radial-gradient(
          closest-side,
          color-mix(in srgb, var(--accent-500), transparent 84%),
          transparent 72%
        );
      }
      .icon {
        position: relative;
        width: 72px;
        height: 72px;
        border-radius: 20px;
        display: grid;
        place-items: center;
        margin: 0 auto 22px;
        font-size: 30px;
        background: var(--accent-50);
        color: var(--accent-600);
        border: 1px solid color-mix(in srgb, var(--accent-500), transparent 80%);
      }
      h1 {
        position: relative;
        font-size: 30px;
        font-weight: 800;
        letter-spacing: -0.03em;
      }
      p {
        position: relative;
        color: var(--ink-3);
        font-size: 16px;
        margin: 10px 0 26px;
        line-height: 1.55;
      }
      a.btn {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 9px;
        background: var(--accent-500);
        color: var(--accent-contrast);
        padding: 13px 24px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 15px;
        text-decoration: none;
        box-shadow: 0 8px 20px -8px color-mix(in srgb, var(--accent-500), transparent 45%);
        transition:
          background 0.2s,
          transform 0.15s ease;
      }
      a.btn:hover {
        background: var(--accent-600);
      }
      a.btn:active {
        transform: translateY(1px);
      }
    </style>
    @vite(['inertia/css/brand_tokens.css'])
  </head>
  <body>
    <div class="page">
      <div class="icon"><i class="pi pi-ticket"></i></div>
      <h1>Invitation not found</h1>
      <p>This invitation link is invalid or has expired.</p>
      <a class="btn" href="/"><i class="pi pi-home"></i> Go to homepage</a>
    </div>
  </body>
</html>
